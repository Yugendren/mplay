#!/bin/bash
# Browse Media downloads and add SPECIFIC folders to the library.
# Uses the exact same organizing logic as `mplay-sync` (process_top_dir from
# mplay-lib.sh): tag-based artist/album hierarchy, disc collapse, aliases,
# cover art. Pick one or many top-level folders with fzf (Tab = multi-select).

source "$HOME/.local/bin/mplay-lib.sh"

if ! ensure_mounted; then
    echo "Error: SMB share not mounted at $DOWNLOADS"
    exit 1
fi
mkdir -p "$LIBRARY"

# Build the shared linked-index once: used both to hide already-present folders
# below and (by process_top_dir) to skip already-linked files during the add.
build_linked_index
LINKED="$LINKED_INDEX"

# Build the list of top-level folders that contain audio and aren't in the library yet.
NEW=()
while IFS= read -r -d '' top; do
    find -E "$top" -type f -iregex ".*${AUDIO_EXTS}" -print -quit 2>/dev/null | grep -q . || continue
    if [ -n "$LINKED" ] && grep -qF "$top/" <<< "$LINKED"; then
        continue
    fi
    NEW+=("$(basename "$top")")
done < <(find "$DOWNLOADS" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

if [ ${#NEW[@]} -eq 0 ]; then
    echo "No new folders found in $DOWNLOADS"
    exit 0
fi

# Fuzzy picker (multi-select with Tab)
SELECTED=$(printf '%s\n' "${NEW[@]}" | \
    fzf --multi --prompt="Select folders to add (Tab=multi-select, Enter=confirm): " \
        --header="Folders not yet in library" \
        --preview="ls '${DOWNLOADS}/{}'" \
        --height=80%)

[ -z "$SELECTED" ] && { echo "Nothing selected."; exit 0; }

# Run each selected folder through the shared organizing logic
while IFS= read -r name; do
    echo "Adding: $name"
    process_top_dir "$DOWNLOADS/$name"
done <<< "$SELECTED"

mpd_update --wait
echo "Done!"
