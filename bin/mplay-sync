#!/bin/bash
# Full library sync: walk EVERY folder in Media downloads and (re)organize it
# into the local library. Use this to rebuild the whole library from scratch.
# For adding a specific new folder, use `mplay-add` instead (same logic, scoped).
# Handles flac, mp3, m4a, opus, ogg, wav, aac.

source "$HOME/.local/bin/mplay-lib.sh"

ensure_mounted || exit 1
mkdir -p "$LIBRARY"

build_linked_index

find "$DOWNLOADS" -mindepth 1 -maxdepth 1 -type d -print0 | while IFS= read -r -d '' top; do
    process_top_dir "$top"
done

mpd_update
