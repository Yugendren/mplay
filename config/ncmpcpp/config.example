mpd_music_dir = __MUSIC_DIR__
ncmpcpp_directory = ~/.config/ncmpcpp

# Display
user_interface = alternative
startup_screen = browser
media_library_primary_tag = album_artist
media_library_albums_split_by_date = no
browser_sort_mode = name

# Tab / Shift-Tab toggle only between Browser (file tree) and Media Library (3-column tag view)
screen_switcher_mode = "browser, media_library"

# Now playing
song_list_format = {$4%a - }{%t}|{$8%f$9}$R{$3(%l)$9}
song_status_format = $b{{$8"%t"}} $3by {$4%a}{ $3in $7%b}{ (%y)}$/b
song_library_format = {%n - }{%t}|{%f}
current_item_prefix = $(cyan)$r
current_item_suffix = $/r$(end)

# Progress bar
progressbar_look = "━━╸"
progressbar_color = cyan:b
progressbar_elapsed_color = green:b

# Colors
colors_enabled = yes
main_window_color = white
header_window_color = cyan
state_line_color = cyan
volume_color = green:b
# Mode flags (r/z/y/R/x) — bright yellow when active so RANDOM is unmistakable
state_flags_color = yellow:b

# Other
mouse_support = yes
cyclic_scrolling = yes
mouse_list_scroll_whole_page = no
lines_scrolled = 1
